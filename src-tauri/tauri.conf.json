{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Civitai Browser",
  "version": "2.1.1",
  "identifier": "com.fabwaseem.civitai-browser",
  "build": {
    "beforeDevCommand": "pnpm dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "pnpm build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Civitai Browser",
        "width": 1440,
        "height": 900,
        "minWidth": 960,
        "minHeight": 640,
        "decorations": false,
        "dragDropEnabled": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": [
      "nsis"
    ],
    "createUpdaterArtifacts": true,
    "icon": [
      "icons/32x32.png",
      "icons/64x64.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IEI2QzM1RTdGNjJBNUEwMTgKUldRWW9LVmlmMTdEdG5qM1o0cVM5K3V5cTJndWRvcWhQeGVXTWVYVm95OWVwMVBkM3JWNXZPbTQK",
      "endpoints": [
        "https://github.com/fabwaseem/civitai-browser/releases/latest/download/latest.json"
      ]
    }
  }
}
